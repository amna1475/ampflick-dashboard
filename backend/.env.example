# Copy this file to ".env" and fill in your real values. Never commit the real ".env" file.

# Your MongoDB Atlas connection string (see README for how to get this)
# IMPORTANT: add your database name right after ".net/" — e.g. ".net/ampflick?retryWrites=true&w=majority"
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/ampflick?retryWrites=true&w=majority

# Port the backend server will run on
PORT=5000

# Allowed origin for CORS — your React frontend's URL during development
CLIENT_ORIGIN=http://localhost:5173

# Secret key used to sign login tokens (JWT). Use a long, random, unguessable string.
# You can generate one quickly by running: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
